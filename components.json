{
  "$schema": "https://shadcn-vue.com/schema.json",
  "style": "default",
  "typescript": true,
  "tsConfigPath": "./tsconfig.json",
  "framework": "nuxt",
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/assets/css/main.css",
    "baseColor": "slate",
    "cssVariables": true,
    "prefix": ""
  },
  "aliases": {
    "components": "~/components",
    "utils": "~/utils/merge",
    "ui": "~/components/ui",
    "lib": "~/lib",
    "hooks": "~/composables"
  }
}
